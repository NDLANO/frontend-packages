{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "tui": {
    "autoExit": true,
    "enabled": false
  },
  "targetDefaults": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["{projectRoot}/dist/**/*.mjs", "{projectRoot}/dist/**/*.mjs.map"],
      "cache": true
    },
    "prepublish": {
      "dependsOn": ["^prepublish"],
      "inputs": [
        "{workspaceRoot}/tsconfig.json",
        "{workspaceRoot}/tsconfig.build.json",
        "{projectRoot}/*",
        "{projectRoot}/src/**/*"
      ],
      "outputs": ["{projectRoot}/dist/**/.d.ts"],
      "cache": true
    },
    "dev": {
      "cache": false
    }
  },
  "defaultBase": "master",
  "namedInputs": {
    "default": ["{projectRoot}/**/*", "sharedGlobals"],
    "sharedGlobals": [],
    "production": ["default"]
  },
  "analytics": false
}
