{
  "name": "@ndla/styled-system",
  "type": "module",
  "description": "Styled System for NDLA",
  "version": "0.0.49",
  "repository": {
    "type": "git",
    "url": "https://github.com/NDLANO/frontend-packages.git",
    "directory": "packages/styled-system"
  },
  "scripts": {
    "build": "tsdown"
  },
  "sideEffects": false,
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "react": ">= 18",
    "react-dom": ">= 18"
  },
  "devDependencies": {
    "@pandacss/dev": "^1.10.0"
  },
  "files": [
    "dist"
  ],
  "exports": {
    "./css": {
      "types": "./dist/css/index.d.ts",
      "import": "./dist/css/index.mjs"
    },
    "./tokens": {
      "types": "./dist/tokens/index.d.ts",
      "import": "./dist/tokens/index.mjs"
    },
    "./types": {
      "types": "./dist/types/index.d.ts"
    },
    "./patterns": {
      "types": "./dist/patterns/index.d.ts",
      "import": "./dist/patterns/index.mjs"
    },
    "./jsx": {
      "types": "./dist/jsx/index.d.ts",
      "import": "./dist/jsx/index.mjs"
    }
  }
}
